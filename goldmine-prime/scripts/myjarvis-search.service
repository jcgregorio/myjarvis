[Unit]
Description=myjarvis hybrid search sidecar (SPLADE+BM25 over Qdrant)
After=network.target docker.service

[Service]
Type=simple
WorkingDirectory=/home/jcgregorio/myjarvis/goldmine-prime
ExecStart=/home/jcgregorio/myjarvis/goldmine-prime/.venv/bin/uvicorn search-server:app --host 0.0.0.0 --port 8011
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
